# Copy this file to application-dev.properties and fill in your values.
# application.properties holds non-sensitive defaults — do not put secrets there.

# PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/momentum
spring.datasource.username=your_db_user
spring.datasource.password=your_db_password
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA — verbose SQL in dev
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# Flyway
spring.flyway.user=your_db_user
spring.flyway.password=your_db_password

# JWT — generate a strong random secret for prod
app.jwt.secret=your_jwt_secret_here

# Swagger — enabled in dev
springdoc.api-docs.enabled=true
springdoc.swagger-ui.enabled=true
springdoc.swagger-ui.path=/swagger-ui.html
